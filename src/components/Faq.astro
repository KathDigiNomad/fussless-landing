---
import { config } from '@/config';
const faq = config.faq;
---

{faq && faq.length > 0 && (
  <section id="faq" class="section-y">
    <div class="container-x max-w-3xl">
      <h2 class="font-display text-4xl md:text-5xl font-bold text-ink mb-12 text-center">
        Frequently asked questions
      </h2>
      <div class="space-y-4">
        {faq.map((item) => (
          <details class="group bg-surface rounded-xl p-5 border border-ink/10 open:border-ink/25 transition-colors">
            <summary class="font-display text-lg font-bold text-ink cursor-pointer list-none flex items-center justify-between gap-4">
              <span>{item.question}</span>
              <span class="text-brand-dark text-2xl leading-none transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-4 text-ink-soft leading-relaxed">
              {item.answer}
            </p>
          </details>
        ))}
      </div>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    })} />
  </section>
)}
