---
import { config } from '@/config';
const { howItWorks } = config;
---

{howItWorks && (
  <section class="section-y">
    <div class="container-x">
      <h2 class="font-display text-4xl md:text-5xl font-bold text-ink mb-12 text-center">
        {howItWorks.title}
      </h2>
      <ol class="grid md:grid-cols-3 gap-8 md:gap-12 list-none p-0">
        {howItWorks.steps.map((step) => (
          <li>
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-dark text-cream font-display text-xl font-bold mb-4">
              {step.number}
            </div>
            <h3 class="font-display text-2xl font-bold text-ink mb-3">
              {step.title}
            </h3>
            <p class="text-ink-soft leading-relaxed">
              {step.body}
            </p>
          </li>
        ))}
      </ol>
    </div>
  </section>
)}
