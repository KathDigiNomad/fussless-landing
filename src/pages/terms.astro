---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { config } from '@/config';
---

<BaseLayout title={`Terms — ${config.name}`} description={`Terms of service for ${config.name}.`}>
  <Header />
  <main id="main" class="container-x max-w-prose py-16">
    <h1 class="font-display text-4xl font-bold text-ink mb-6">Terms of service</h1>
    <p class="text-ink-soft mb-4">Last updated: 9 July 2026</p>
    <p class="text-ink-soft mb-4">
      This is a placeholder terms document. Replace with your actual terms before going live.
    </p>
  </main>
  <Footer />
</BaseLayout>
